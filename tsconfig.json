{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": false,
    "jsx": "preserve",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "examples/*"
      ],
      "at-materia": [
        "src/index.ts"
      ]
    },
    "types": [
      "node",
      "vite/client",
      "vue/jsx"
    ]
  },
  "include": [
    "src/**/*",
    "examples/**/*",
    "env.d.ts",
    "vite.config.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
