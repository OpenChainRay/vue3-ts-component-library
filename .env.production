# 环境变量
# NODE_ENV 由 Vite 配置注入，避免 .env 中定义触发告警
BABEL_ENV = production
# 是否开启 CDN 支持，
APP_CDN = OFF
# 是否开启 gzip 压缩，
APP_GZIP = YES
# public path
PUBLIC_PATH = /dist/


# dev
# APP_API_BASE_URL = http://gateway.dev.ant2world.com/at-oms-api

# 外网
# APP_API_BASE_URL = http://gateway.antuat.ant-fa.com/at-oms-api
#uat
# APP_API_BASE_URL = http://gateway.anttest.ant-fa.com/at-oms-api

APP_API_BASE_URL = http://oms.antuat.ant-fa.com/api/at-oms-api

# dev 登陆接口
# APP_UMS_URL = http://gateway.dev.ant2world.com/at-ums-api

# 外网
# APP_UMS_URL = http://gateway.anttest.ant-fa.com/at-ums-api
#uat
# APP_UMS_URL = http://gateway.antuat.ant-fa.com/at-ums-api

APP_UMS_URL = http://oms.antuat.ant-fa.com/api/at-ums-api

APP_WORKFLOW_URL = http://gateway.uat.ant2world.com/at-workflow-api

APP_SRM_URL = http://gateway.dev.ant2world.com/at-srm-api
APP_CMS_URL = http://gateway.dev.ant2world.com/at-base-api
APP_ARMS_URL = http://gateway.dev.ant2world.com/at-arms-api

