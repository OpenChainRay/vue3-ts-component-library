{
  "sourceType": "unambiguous",
  "presets": [
    [
      // "@babel/preset-env",
      "@vue/babel-preset-jsx",
      {
        "modules": false,
        "targets": {
          "browsers": ["> 1%", "last 2 versions", "not ie <= 8"]
        },
        "useBuiltIns": "usage", // 按需加载垫片
        "corejs": {
          "version": 3,
          "proposals": true
        },
        // 使用赋值法直接定义 (https://babeljs.io/docs/en/babel-plugin-proposal-class-properties.html)
        "loose": true
        // "debug": true,

      }
    ]
  ],
  "plugins": [
    // "@vue/babel-plugin-jsx", // vue3.0
    [
      "@babel/plugin-proposal-class-properties",
      {
        // 使用赋值法直接定义 (https://babeljs.io/docs/en/babel-plugin-proposal-class-properties.html)
        "loose": true
      }
    ],
    [
      "@babel/plugin-transform-runtime",
      {
        // 产生更小的构建输出，因为它不需要保留 CommonJS 的语义代码
        "useESModules": true
      }
    ]
    // ["import",{
    //   "libraryName": "ant",
    //   "libraryDirectory": "es",
    //   "style": true
    // }]
  ],
  "env": {
    "development": {
      "plugins": ["dynamic-import-node"]
    }
  }
}
