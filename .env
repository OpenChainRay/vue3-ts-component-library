# 页面标题
GLOBE_APP_TITLE = 爱安特oms

# port
# SERVE_PORT = 3100

# localStorage本地缓存 存/取 key值
# 用户简要信息对象(如：名字、头像等)
APP_USER_KEY=userInfo

# TabView下标签名称
APP_TABS_TITLES_KEY=appTabsTitles
APP_TABS_KEY=appTabs

# 用户所能访问的路由集合
APP_ROUTES_KEY=userRoutes
# 用户角色
APP_ROLES_KEY=userRoles
# 用户权限
APP_PERMISSIONS_KEY=userPermissions



# 集团所有公司
APP_ORGANIZATIONS_KEY=allOrganizations

# 用所选当前组织（公司）
APP_USER_ORGANIZATION=currentOrganization
# 用所选当前部门
APP_USER_DEPARTMENT=currentDepartment
